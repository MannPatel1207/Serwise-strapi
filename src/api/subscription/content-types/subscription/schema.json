{
  "kind": "collectionType",
  "collectionName": "subscriptions",
  "info": {
    "singularName": "subscription",
    "pluralName": "subscriptions",
    "displayName": "Subscription"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "plan_type": {
      "type": "enumeration",
      "enum": [
        "Basic",
        "Standard",
        "Addon"
      ],
      "required": true
    },
    "totalServices": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "serviceMapping": {
      "type": "component",
      "repeatable": true,
      "component": "subscription.service-mapping"
    },
    "cost": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "sub_sales": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "non_sub_sales": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "sub_profit": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "non_sub_profit": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "maxDiscount": {
      "type": "decimal",
      "default": 0
    },
    "lockInPeriod": {
      "type": "integer",
      "default": 0
    },
    "validityDuration": {
      "type": "integer",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "device_types": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::device-type.device-type"
    }
  }
}

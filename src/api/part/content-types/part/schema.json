{
  "kind": "collectionType",
  "collectionName": "parts",
  "info": {
    "singularName": "part",
    "pluralName": "parts",
    "displayName": "Part"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Basic Filters",
        "Additional Filters",
        "Electrical Components",
        "Other Items",
        "Pipe & Fittings",
        "Core"
      ]
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Parts",
        "Repair",
        "Service"
      ]
    },
    "price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "quantity": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "description": {
      "type": "text",
      "required": false
    },
    "visibility": {
      "type": "enumeration",
      "required": true,
      "default": "DRAFT",
      "enum": [
        "ACTIVE",
        "DRAFT",
        "DISCONTINUED"
      ]
    }
  }
}
